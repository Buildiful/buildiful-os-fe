#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

show_help() {
  cat <<'EOF'
Buildiful OS [Founder Edition]

Usage:
  bos <command>

Commands:
  version   Show BOS version information
  status    Show current BOS status
  doctor    Run basic BOS health checks
  dirs      List Buildiful workspace directories
  apps      List installed app packs
  docs      Show local docs location
  backup    Create a backup archive
  launch    Open the BOS home screen if available
  help      Show this help message
EOF
}

run_subcommand() {
  local script_name="$1"
  shift || true

  if [[ -x "${SCRIPT_DIR}/${script_name}" ]]; then
    "${SCRIPT_DIR}/${script_name}" "$@"
  else
    echo "ERROR: Missing command implementation: ${script_name}"
    exit 1
  fi
}

COMMAND="${1:-help}"

case "${COMMAND}" in
  version)
    run_subcommand "bos-version.sh"
    ;;
  status)
    run_subcommand "bos-status.sh"
    ;;
  doctor)
    run_subcommand "bos-doctor.sh"
    ;;
  dirs)
    run_subcommand "bos-dirs.sh"
    ;;
  apps)
    run_subcommand "bos-apps.sh"
    ;;
  docs)
    run_subcommand "bos-docs.sh"
    ;;
  backup)
    run_subcommand "bos-backup.sh"
    ;;
  launch)
    run_subcommand "bos-launch.sh"
    ;;
  help|-h|--help)
    show_help
    ;;
  *)
    echo "ERROR: Unknown command: ${COMMAND}"
    echo
    show_help
    exit 1
    ;;
esac